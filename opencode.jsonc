{
	"$schema": "https://opencode.ai/config.json",
	"instructions": [".agent/rules/*.md", "agentmap.md"],
	"formatter": {
		"prettier": {
			"command": ["pnpx", "prettier", "--write", "$FILE"],
			"environment": {
				"NODE_ENV": "development"
			}
		}
	},
	"plugin": ["@tarquinen/opencode-dcp@latest", "@nick-vi/opencode-type-inject", "@mohak34/opencode-notifier@latest"]
}
