{
	"name": "monorepo",
	"author": "1yasa",
	"private": true,
	"packageManager": "pnpm@10.28.2",
	"scripts": {
		"deps": "ncu -i",
		"build:deps": "turbo run deps",
		"build:mac": "turbo run desktop#pack:mac",
		"build:win": "turbo run desktop#pack:win",
		"submodule:init": "git submodule update --init --recursive",
		"submodule:update": "git submodule sync && git submodule update --recursive --remote --merge",
		"deps:catalog": "pcu -i"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm pretty-quick --pattern \"**/*.*(md|css|js|jsx|ts|tsx)\" --staged"
	},
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "^4.7.0",
		"@types/node": "catalog:",
		"pnpm-catalog-updates": "^1.1.8",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss-pro": "^0.2.0",
		"pretty-quick": "^4.2.2",
		"simple-git-hooks": "^2.13.1",
		"tsx": "^4.21.0",
		"turbo": "^2.8.1"
	},
	"dependencies": {
		"@electric-sql/pglite": "^0.3.15",
		"@google/generative-ai": "^0.24.1",
		"piscina": "^5.1.4"
	}
}
