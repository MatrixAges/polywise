{
  "name": "desktop",
  "productName": "Polywise",
  "author": "1yasa",
  "version": "0.0.0",
  "main": "dist/index.js",
  "scripts": {
    "clean": "bun ./build/clean",
    "watch": "delay 300ms && bun ./scripts/dev",
    "shell": "electron .",
    "dev": "concurrently \"pnpm run main:dev\" \"pnpm run watch\"",
    "main:dev": "cross-env NODE_ENV=development rslib build --watch",
    "main:prod": "cross-env NODE_ENV=production rslib build",
    "transform": "cross-env NODE_ENV=production bun ./build/transform",
    "build": "pnpm run main:prod && pnpm run transform",
    "pack:mac": "pnpm run clean && pnpm run transform && pnpm run main:prod && concurrently \"cross-env ZIP=0 electron-builder -m\" \"electron-builder -m\"",
    "pack:win": "pnpm run clean && pnpm run transform && pnpm run main:prod && electron-builder -w"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.36",
    "@hono/node-server": "^1.19.9",
    "@trpc/server": "^11.10.0",
    "ai": "catalog:",
    "atomically": "^2.1.1",
    "await-to-js": "^3.0.0",
    "dayjs": "catalog:",
    "deepmerge-ts": "^7.1.5",
    "dotenv": "^17.3.1",
    "electron-conf": "^1.3.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "erpc": "workspace:*",
    "es-toolkit": "catalog:",
    "fs-extra": "catalog:",
    "hono": "^4.12.3",
    "i18next": "catalog:",
    "minimatch": "^10.2.4",
    "ofetch": "^1.5.1",
    "polywise": "workspace:*",
    "watchpack": "^2.5.1",
    "workerpool": "^10.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@rslib/core": "catalog:",
    "@types/fs-extra": "catalog:",
    "@types/node": "^25.3.2",
    "@types/watchpack": "^2.4.5",
    "@types/workerpool": "^9.0.0",
    "bun": "catalog:",
    "bun-types": "catalog:",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "delay-cli": "^3.0.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "glob": "^13.0.6",
    "tinyglobby": "^0.2.15",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {},
  "optionalDependencies": {}
}