{
	"name": "desktop",
	"productName": "Polywise",
	"author": "1yasa",
	"version": "0.1.0",
	"main": "dist/index.js",
	"scripts": {
		"clean": "bun ./build/clean && npm run rebuild",
		"watch": "delay 300ms && bun ./scripts/dev",
		"shell": "electron .",
		"dev": "concurrently \"npm run main:dev\" \"npm run watch\"",
		"main:dev": "cross-env NODE_ENV=development rslib build --watch",
		"main:prod": "cross-env NODE_ENV=production rslib build",
		"transform": "cross-env NODE_ENV=production bun ./build/transform",
		"build": "npm run main:prod && npm run transform",
		"build:mac": "npm run clean && npm run transform && npm run main:prod && concurrently \"cross-env ZIP=0 electron-builder -m\" \"electron-builder -m\"",
		"build:win": "npm run clean && npm run transform && npm run main:prod && electron-builder -w",
		"rebuild": "cross-env CI=true npm rebuild better-sqlite3 bufferutil lmdb node-llama-cpp simsimd sqlite-vec utf-8-validate @node-rs/jieba @node-rs/xxhash"
	},
	"dependencies": {
		"@trpc/server": "catalog:",
		"atomically": "^2.1.1",
		"await-to-js": "catalog:",
		"dayjs": "catalog:",
		"deepmerge-ts": "catalog:",
		"dotenv": "^17.4.2",
		"electron-conf": "catalog:",
		"electron-log": "^5.4.4",
		"electron-updater": "^6.8.3",
		"erpc": "workspace:*",
		"es-toolkit": "catalog:",
		"fs-extra": "catalog:",
		"i18next": "catalog:",
		"minimatch": "^10.2.5",
		"ofetch": "catalog:",
		"polywise": "workspace:*",
		"watchpack": "^2.5.1",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@electron/notarize": "^3.1.1",
		"@rslib/core": "catalog:",
		"@types/fs-extra": "catalog:",
		"@types/node": "catalog:",
		"@types/watchpack": "^2.4.5",
		"bun": "catalog:",
		"bun-types": "catalog:",
		"chalk": "^5.6.2",
		"concurrently": "^9.2.1",
		"cross-env": "catalog:",
		"delay-cli": "catalog:",
		"electron": "catalog:",
		"electron-builder": "26.5.0",
		"glob": "^13.0.6",
		"tinyglobby": "catalog:",
		"typescript": "catalog:"
	}
}
