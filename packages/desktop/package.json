{
  "name": "desktop",
  "productName": "Polywise",
  "author": "1yasa",
  "version": "0.0.0",
  "main": "dist/index.js",
  "scripts": {
    "clean": "bun ./build/clean",
    "watch": "delay 300ms && bun ./scripts/dev",
    "shell": "electron .",
    "dev": "concurrently \"pnpm run main:dev\" \"pnpm run watch\"",
    "main:dev": "cross-env NODE_ENV=development rslib build --watch",
    "main:prod": "cross-env NODE_ENV=production rslib build",
    "transform": "cross-env NODE_ENV=production bun ./build/transform",
    "build": "pnpm run main:prod && pnpm run transform",
    "pack:mac": "pnpm run clean && pnpm run transform && pnpm run main:prod && concurrently \"cross-env ZIP=0 electron-builder -m\" \"electron-builder -m\"",
    "pack:win": "pnpm run clean && pnpm run transform && pnpm run main:prod && electron-builder -w"
  },
  "dependencies": {
    "@ai-sdk/openai": "catalog:",
    "@hono/node-server": "^1.19.9",
    "@trpc/server": "catalog:",
    "ai": "catalog:",
    "atomically": "^2.1.1",
    "await-to-js": "catalog:",
    "dayjs": "catalog:",
    "deepmerge-ts": "catalog:",
    "dotenv": "^17.3.1",
    "electron-conf": "catalog:",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "erpc": "workspace:*",
    "es-toolkit": "catalog:",
    "fs-extra": "catalog:",
    "hono": "catalog:",
    "i18next": "catalog:",
    "minimatch": "^10.2.4",
    "ofetch": "catalog:",
    "polywise": "workspace:*",
    "watchpack": "^2.5.1",
    "workerpool": "^10.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@rslib/core": "catalog:",
    "@types/fs-extra": "catalog:",
    "@types/node": "catalog:",
    "@types/watchpack": "^2.4.5",
    "@types/workerpool": "^9.0.0",
    "bun": "catalog:",
    "bun-types": "catalog:",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "cross-env": "catalog:",
    "delay-cli": "^3.0.0",
    "electron": "catalog:",
    "electron-builder": "^26.8.1",
    "glob": "^13.0.6",
    "tinyglobby": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {},
  "optionalDependencies": {}
}
