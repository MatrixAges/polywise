{
  "name": "desktop",
  "productName": "Polywise",
  "author": "1yasa",
  "version": "0.0.2",
  "main": "dist/index.js",
  "scripts": {
    "polywise:build": "npm --prefix ../polywise run build:electron",
    "clean": "bun ./build/clean",
    "watch": "delay 300ms && bun ./scripts/dev",
    "shell": "electron .",
    "dev": "cross-env DEVTOOL=1 concurrently \"npm run main:dev\" \"npm run watch\"",
    "build:mac:debug": "npm run polywise:build && npm run clean && npm run main:prod && npm run transform && electron-builder -m",
    "main:dev": "cross-env NODE_ENV=development rslib build --watch",
    "main:prod": "cross-env NODE_ENV=production rslib build",
    "transform": "cross-env NODE_ENV=production bun ./build/transform",
    "build": "npm run polywise:build && npm run rebuild && npm run main:prod && npm run transform",
    "build:mac": "npm run polywise:build && npm run clean && npm run main:prod && npm run transform && concurrently \"cross-env ZIP=0 electron-builder -m\" \"electron-builder -m\"",
    "build:win": "npm run polywise:build && npm run clean && npm run main:prod && npm run transform && electron-builder -w",
    "rebuild": "node ./scripts/rebuild.mjs"
  },
  "dependencies": {
    "@trpc/server": "catalog:",
    "atomically": "^2.1.1",
    "await-to-js": "catalog:",
    "dayjs": "catalog:",
    "deepmerge-ts": "catalog:",
    "dotenv": "^17.4.2",
    "electron-conf": "catalog:",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "erpc": "workspace:*",
    "es-toolkit": "catalog:",
    "fs-extra": "catalog:",
    "i18next": "catalog:",
    "minimatch": "^10.2.5",
    "ofetch": "catalog:",
    "polywise": "workspace:*",
    "watchpack": "^2.5.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@rslib/core": "catalog:",
    "@types/fs-extra": "catalog:",
    "@types/node": "catalog:",
    "@types/watchpack": "^2.4.5",
    "bun": "catalog:",
    "bun-types": "catalog:",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "cross-env": "catalog:",
    "delay-cli": "catalog:",
    "electron": "catalog:",
    "electron-builder": "26.5.0",
    "glob": "^13.0.6",
    "tinyglobby": "catalog:",
    "typescript": "catalog:"
  }
}
