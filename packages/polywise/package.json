		"@electric-sql/pglite": "^0.3.16",
		"@node-rs/jieba": "^2.0.1",
		"@node-rs/xxhash": "^1.7.6",
		"@trpc/server": "catalog:",
		"@hono/trpc-server": "catalog:",
		"@hono/node-server": "catalog:",
		"ansis": "catalog:",
		"await-to-js": "catalog:",
		"better-auth": "^1.5.5",
		"dayjs": "catalog:",
		"drizzle-kit": "1.0.0-beta.16-ea816b6",
		"drizzle-orm": "1.0.0-beta.16-ea816b6",
		"es-toolkit": "catalog:",
		"fastq": "^1.20.1",
		"fs-extra": "catalog:",
