{
	"name": "polywise",
	"type": "module",
	"version": "0.0.0",
	"main": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "cross-env NODE_ENV=development rslib build --watch",
		"build": "rslib build",
		"server": "bun ./src/index.ts",
		"test": "rstest run $TEST_FILE",
		"sql": "drizzle-kit generate",
		"auth:sql": "pnpx auth generate --adapter drizzle",
		"auth:migrate": "pnpx auth migrate"
	},
	"dependencies": {
		"@abraham/reflection": "catalog:",
