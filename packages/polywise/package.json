{
	"name": "polywise",
	"version": "0.0.0",
	"type": "module",
	"main": "./dist/index.js",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"./package.json"
	],
	"scripts": {
		"build": "cross-env NODE_ENV=production rslib build",
		"build:watch": "cross-env NODE_ENV=development rslib build --watch",
		"start": "node ./dist/index.js",
		"start:watch": "delay 300ms && node --watch ./dist/index.js",
		"dev": "concurrently -c \"cyan,magenta\" \"pnpm run build:watch\" \"pnpm run start:watch\"",
		"test": "rstest run $TEST_FILE",
		"sql": "drizzle-kit generate",
		"auth:sql": "pnpx auth generate --adapter drizzle",
		"auth:migrate": "pnpx auth migrate",
		"studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@abraham/reflection": "catalog:",
		"@ai-sdk/mcp": "^1.0.30",
		"@ai-sdk/openai": "catalog:",
		"@ai-sdk/provider-utils": "catalog:",
		"@better-auth/drizzle-adapter": "^1.5.6",
		"@chonkiejs/core": "^0.0.8",
		"@drizzle-team/brocli": "^0.11.0",
		"@hono/node-server": "catalog:",
		"@hono/trpc-server": "catalog:",
		"@hono/zod-validator": "^0.7.6",
		"@mcpc-tech/acp-ai-provider": "^0.3.0",
		"@node-rs/jieba": "^2.0.1",
		"@node-rs/xxhash": "^1.7.6",
		"@trpc/server": "catalog:",
		"ai": "catalog:",
		"ansis": "catalog:",
		"await-to-js": "catalog:",
		"bash-tool": "^1.3.15",
		"better-auth": "^1.5.6",
		"better-sqlite3": "^12.8.0",
		"dayjs": "catalog:",
		"drizzle-kit": "1.0.0-beta.16-ea816b6",
		"drizzle-orm": "1.0.0-beta.16-ea816b6",
		"es-toolkit": "catalog:",
		"evlog": "^2.9.0",
		"fastq": "^1.20.1",
		"fs-extra": "catalog:",
		"hono": "catalog:",
