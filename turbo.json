{
	"$schema": "https://turborepo.org/schema.json",
	"tasks": {
		"erpc#build": {
			"outputs": ["dist/**"],
			"cache": true
		},
		"stk#build": {
			"outputs": ["dist/**"],
			"cache": true
		},
		"deps": {
			"dependsOn": ["erpc#build", "stk#build"]
		},
		"app#build": {
			"dependsOn": ["deps"],
			"outputs": ["dist/**"]
		},
		"desktop#pack:mac": {
			"dependsOn": ["app#build"],
			"outputs": ["dist/**"]
		},
		"desktop#pack:win": {
			"dependsOn": ["app#build"],
			"outputs": ["dist/**"]
		}
	}
}
